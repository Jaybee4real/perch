#!/usr/bin/env bash
# perch — start/restart long-running dev servers in named, reusable Terminal.app tabs.
#
# Each server "perches" in its own titled tab. Re-invoke with the same name and it
# returns to the same perch (reusing that tab) instead of flying off into a new window.
#
# Run `perch help` for usage.
set -euo pipefail

PERCH_VERSION="2.3.0"
CONFIG="${PERCH_CONFIG:-$HOME/.config/perch/projects.conf}"
FAVORITES="${PERCH_FAVORITES:-$HOME/.config/perch/favorites}"
CATEGORIES="${PERCH_CATEGORIES:-$HOME/.config/perch/categories.conf}"
CAT_ORDER="metro landing web backend admin other"
BOUNDS="${PERCH_BOUNDS:-$HOME/.config/perch/window-bounds}"
REMEMBER_BOUNDS="${PERCH_REMEMBER_BOUNDS:-1}"
SPACES="${PERCH_SPACES:-$HOME/.config/perch/spaces.conf}"
SETTINGS="${PERCH_SETTINGS:-$HOME/.config/perch/settings}"

usage() {
  cat <<'EOF'
perch — named dev-server tabs for Terminal.app

USAGE
  perch <project>                        launch a registered project
  perch <prefix>                         start a whole product cluster (e.g. perch jakstoc = every jakstoc-*)
  perch <marker> <dir> <port> <command>  launch anything ad-hoc (port "-" to skip the port kill)
  perch fav                              interactive multi-select picker; saves + launches favorites
  perch fav go                           launch your saved favorites (no menu)
  perch fav set <name...>                replace favorites with the given projects
  perch fav add <name...>                add projects to favorites
  perch fav list                         show saved favorites
  perch fav clear                        remove all favorites
  perch pick                             alias for `perch fav`
  perch place [fav]                      move open windows to their desktops + tile full-width, stacked
  perch place [fav] notile               move to desktops but keep free-floating positions
  perch set                              show optional settings (placement, tile)
  perch set placement <on|off>           toggle yabai desktop placement (default on)
  perch set tile <on|off>                toggle full-width stacked tiling (default on)
  perch gui                              open the web dashboard (http://localhost:7620)
  perch gui stop                         stop the dashboard server
  perch setup                            auto-detect this machine's monitors + write the desktop map
  perch doctor                           check dependencies (osascript, python3, yabai) + config
  perch bounds                           list remembered window positions
  perch bounds clear [name]              forget window position(s)
  perch list                             show every registered project and whether it is running
  perch groups                           list projects grouped by product cluster, with ports + status
  perch stop <project|port>              kill whatever holds that project's port
  perch killall                          stop every running registered server (by port)
  perch killall --close                  ...and close their Terminal tabs too
  perch killall fav                      stop only the servers in your favorites
  perch add <name> <port> <dir> <command...>   register a project
  perch remove <name>                    unregister a project
  perch config                           print the config file path
  perch port [name]                      print a project's assigned port (by name, or by current dir)
  perch help                             this text
  perch <command> help                   detailed help for any command (e.g. perch fav add help, perch place help)

EXAMPLES
  perch acme-api                 start the Acme API in its own tab
  perch acme-metro               restart Acme Metro in place
  perch stop acme-web            free a port by project name
  perch my-tool ~/code/my-tool 5000 "npm run dev"

Projects live in ~/.config/perch/projects.conf, one per line:
  name|port|dir|command
EOF
}

expand_path() {
  local value="$1"
  value="${value/#\~/$HOME}"
  printf '%s' "${value//\$HOME/$HOME}"
}

config_lines() {
  [ -f "$CONFIG" ] || return 0
  grep -vE '^\s*(#|$)' "$CONFIG" || true
}

lookup() {
  local wanted="$1" name port dir cmd
  while IFS='|' read -r name port dir cmd; do
    if [ "$name" = "$wanted" ]; then
      printf '%s|%s|%s\n' "$port" "$dir" "$cmd"
      return 0
    fi
  done < <(config_lines)
  return 1
}

free_port() {
  local port="$1" pids
  [ "$port" = "-" ] && return 0
  pids="$(lsof -ti tcp:"$port" 2>/dev/null || true)"
  if [ -n "$pids" ]; then
    # shellcheck disable=SC2086
    kill -9 $pids 2>/dev/null || true
    echo "[perch] freed port $port (killed: $(echo "$pids" | tr '\n' ' '))"
  fi
}

# --- window-position memory ---------------------------------------------------
# macOS does not let scripts assign a window to a Space/Desktop, but Terminal
# does expose window `bounds`. We record each marker's {left,top,right,bottom}
# and restore it when a NEW window has to be opened (a reused tab is left alone).
bounds_lookup() {
  [ -f "$BOUNDS" ] || return 0
  local wanted="$1" name x1 y1 x2 y2
  while IFS='|' read -r name x1 y1 x2 y2; do
    if [ "$name" = "$wanted" ]; then printf '%s %s %s %s' "$x1" "$y1" "$x2" "$y2"; return 0; fi
  done < "$BOUNDS"
}

bounds_save() {
  local marker="$1" b="$2" x1 y1 x2 y2 tmp
  [ -n "$b" ] || return 0
  read -r x1 y1 x2 y2 <<<"$b"
  case "${x1}${y1}${x2}${y2}" in ''|*[!0-9-]*) return 0 ;; esac
  [ -n "$x1" ] && [ -n "$y1" ] && [ -n "$x2" ] && [ -n "$y2" ] || return 0
  mkdir -p "$(dirname "$BOUNDS")"; touch "$BOUNDS"
  tmp="$(mktemp)"
  awk -F'|' -v n="$marker" '$1 != n' "$BOUNDS" >"$tmp" 2>/dev/null || true
  printf '%s|%s|%s|%s|%s\n' "$marker" "$x1" "$y1" "$x2" "$y2" >>"$tmp"
  mv "$tmp" "$BOUNDS"
}

# --- yabai desktop placement (optional) ---------------------------------------
# macOS won't let a script assign a window to a Space, but yabai can. When yabai
# is running, perch moves each server's window to the space mapped in spaces.conf
# (by marker override, else by category) and sets its frame via yabai too.
# --- persistent settings (key=value) ------------------------------------------
pget() {
  local key="$1" def="$2" line
  [ -f "$SETTINGS" ] || { printf '%s' "$def"; return; }
  line="$(grep -E "^$key=" "$SETTINGS" 2>/dev/null | tail -1)"
  if [ -n "$line" ]; then printf '%s' "${line#*=}"; else printf '%s' "$def"; fi
}
pset() {
  local key="$1" val="$2" tmp
  mkdir -p "$(dirname "$SETTINGS")"; touch "$SETTINGS"
  tmp="$(mktemp)"
  grep -vE "^$key=" "$SETTINGS" > "$tmp" 2>/dev/null || true
  printf '%s=%s\n' "$key" "$val" >> "$tmp"
  mv "$tmp" "$SETTINGS"
}

# Desktop placement is OPTIONAL: on by default, toggle with `perch set placement off`.
# Env PERCH_USE_YABAI=0 is a hard override for a single invocation.
placement_enabled() {
  case "${PERCH_USE_YABAI:-}" in 0) return 1 ;; esac
  [ "$(pget placement on)" = "on" ]
}

yabai_available() {
  placement_enabled || return 1
  command -v yabai >/dev/null 2>&1 || return 1
  yabai -m query --spaces >/dev/null 2>&1
}

space_for() {
  local marker="$1" cat="$2" name val
  [ -f "$SPACES" ] || return 0
  while IFS='|' read -r name val; do
    case "$name" in ''|\#*) continue ;; esac
    [ "$name" = "$marker" ] && { printf '%s' "$val" | tr -d ' '; return 0; }
  done < "$SPACES"
  while IFS='|' read -r name val; do
    case "$name" in ''|\#*) continue ;; esac
    [ "$name" = "$cat" ] && { printf '%s' "$val" | tr -d ' '; return 0; }
  done < "$SPACES"
}

yabai_window_id() {
  yabai -m query --windows 2>/dev/null | python3 -c '
import json,sys
m=sys.argv[1]
try: ws=json.load(sys.stdin)
except Exception: sys.exit(0)
for w in ws:
    if w.get("app")=="Terminal" and m in (w.get("title") or ""):
        print(w["id"]); break
' "$1" 2>/dev/null
}

yabai_frame() {
  yabai -m query --windows --window "$1" 2>/dev/null | python3 -c '
import json,sys
try: f=json.load(sys.stdin)["frame"]
except Exception: sys.exit(0)
print(int(f["x"]),int(f["y"]),int(f["x"]+f["w"]),int(f["y"]+f["h"]))
' 2>/dev/null
}

# Resolve a space spec to a live yabai space index. A plain number is returned
# as-is; "<display>:<ordinal>" resolves to the ordinal-th NON-fullscreen desktop
# on that display (1-based) — stable even when fullscreen apps renumber indices.
resolve_space() {
  local spec="$1"
  case "$spec" in
    *:*)
      local disp="${spec%%:*}" ord="${spec#*:}"
      yabai -m query --spaces --display "$disp" 2>/dev/null | python3 -c '
import json,sys
try: ord=int(sys.argv[1])
except Exception: sys.exit(0)
sp=[s for s in json.load(sys.stdin) if not s.get("is-native-fullscreen")]
sp.sort(key=lambda s:s["index"])
if 1<=ord<=len(sp): print(sp[ord-1]["index"])
' "$ord" 2>/dev/null ;;
    *) printf '%s' "$spec" ;;
  esac
}

launch() {
  local marker="$1" dir="$2" port="$3" cmd="$4"
  dir="$(expand_path "$dir")"
  cmd="$(expand_path "$cmd")"
  [ -d "$dir" ] || { echo "perch: directory not found: $dir" >&2; exit 1; }

  free_port "$port"

  local run="cd \"$dir\" && clear && $cmd"
  esc() { printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'; }
  local marker_esc run_esc
  marker_esc="$(esc "$marker")"
  run_esc="$(esc "$run")"

  local yon=0
  yabai_available && yon=1

  local has_bounds="false" bx1=0 by1=0 bx2=0 by2=0 stored=""
  if [ "$REMEMBER_BOUNDS" = "1" ]; then
    stored="$(bounds_lookup "$marker")"
    if [ -n "$stored" ]; then
      read -r bx1 by1 bx2 by2 <<<"$stored"
      # let Terminal position the window only when yabai is NOT handling placement
      [ "$yon" = "1" ] || has_bounds="true"
    fi
  fi

  local out tmpout
  tmpout="$(mktemp)"
  /usr/bin/osascript >"$tmpout" 2>/dev/null <<OSA
tell application "Terminal"
  set theMarker to "$marker_esc"
  set theCmd to "$run_esc"
  set hasBounds to $has_bounds
  set bx1 to $bx1
  set by1 to $by1
  set bx2 to $bx2
  set by2 to $by2
  set foundTab to missing value
  set foundWin to missing value
  repeat with w in windows
    -- Some Terminal windows (e.g. the Settings window) don't expose tabs; skip them.
    try
      repeat with t in tabs of w
        try
          if (custom title of t) is theMarker then
            set foundTab to t
            set foundWin to w
            exit repeat
          end if
        end try
      end repeat
    end try
    if foundTab is not missing value then exit repeat
  end repeat
  set targetWin to missing value
  set createFlag to "R"
  if foundTab is not missing value then
    do script theCmd in foundTab
    set selected of foundTab to true
    try
      set index of foundWin to 1
    end try
    set targetWin to foundWin
  else
    set createFlag to "C"
    set newTab to do script theCmd
    set custom title of newTab to theMarker
    try
      set targetWin to window 1
    end try
    if hasBounds and targetWin is not missing value then
      try
        set position of targetWin to {bx1, by1}
        set size of targetWin to {bx2 - bx1, by2 - by1}
      end try
    end if
  end if
  activate
  set outB to ""
  try
    if targetWin is not missing value then
      set bb to bounds of targetWin
      set outB to createFlag & " " & ((item 1 of bb) as text) & " " & ((item 2 of bb) as text) & " " & ((item 3 of bb) as text) & " " & ((item 4 of bb) as text)
    end if
  end try
  return outB
end tell
OSA
  out="$(cat "$tmpout" 2>/dev/null)"; rm -f "$tmpout"
  local created="${out%% *}" rest="${out#* }"

  if [ "$yon" = "1" ]; then
    ensure_spaces_seeded
    # yabai path: snap the window to its assigned desktop; restore saved
    # position only on a fresh window (a reused window learns manual moves)
    local ycat ysp ywid tries=0
    ycat="$(categorize "$marker" "$port")"
    ysp="$(resolve_space "$(space_for "$marker" "$ycat")")"
    ywid="$(yabai_window_id "$marker")"
    while [ -z "$ywid" ] && [ "$tries" -lt 6 ]; do sleep 0.3; ywid="$(yabai_window_id "$marker")"; tries=$((tries+1)); done
    if [ -n "$ywid" ]; then
      [ -n "$ysp" ] && yabai -m window "$ywid" --space "$ysp" 2>/dev/null || true
      if [ "$REMEMBER_BOUNDS" = "1" ] && [ "$created" = "C" ] && [ -n "$stored" ]; then
        yabai -m window "$ywid" --resize "abs:$((bx2-bx1)):$((by2-by1))" 2>/dev/null || true
        yabai -m window "$ywid" --move "abs:$bx1:$by1" 2>/dev/null || true
      fi
      if [ "$REMEMBER_BOUNDS" = "1" ]; then
        local yfr; yfr="$(yabai_frame "$ywid")"
        [ -n "$yfr" ] && bounds_save "$marker" "$yfr"
      fi
    fi
  elif [ "$REMEMBER_BOUNDS" = "1" ] && [ -n "$out" ]; then
    # Terminal-only path: save unless we just restored a stored position on a fresh window
    if [ "$created" = "R" ] || [ -z "$stored" ]; then bounds_save "$marker" "$rest"; fi
  fi

  echo "[perch] '$marker' -> $cmd  (tab reused if it existed, else created)"
}

cmd_list() {
  if ! config_lines | grep -q .; then
    echo "perch: no projects registered yet (config: $CONFIG)"
    echo "Register one with: perch add <name> <port> <dir> <command...>"
    return 0
  fi
  printf '%-28s %-6s %-8s %s\n' 'PROJECT' 'PORT' 'STATUS' 'COMMAND'
  local name port dir cmd status
  while IFS='|' read -r name port dir cmd; do
    status='.'
    if [ "$port" != "-" ] && lsof -ti tcp:"$port" >/dev/null 2>&1; then
      status='up'
    fi
    printf '%-28s %-6s %-8s %s\n' "$name" "$port" "$status" "$cmd"
  done < <(config_lines)
}

cmd_stop() {
  local target="${1:?usage: perch stop <project|port>}" port entry
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    port="$target"
  elif entry="$(lookup "$target")"; then
    port="${entry%%|*}"
    [ "$port" != "-" ] || { echo "perch: '$target' has no port to stop" >&2; exit 1; }
  else
    echo "perch: unknown project '$target' (see: perch list)" >&2
    exit 1
  fi
  local pids
  pids="$(lsof -ti tcp:"$port" 2>/dev/null || true)"
  if [ -z "$pids" ]; then
    echo "[perch] nothing running on port $port"
  else
    # shellcheck disable=SC2086
    kill -9 $pids 2>/dev/null || true
    echo "[perch] stopped port $port (killed: $(echo "$pids" | tr '\n' ' '))"
  fi
}

cmd_add() {
  local name="${1:?usage: perch add <name> <port> <dir> <command...>}"
  local port="${2:?port required (or - for none)}"
  local dir="${3:?dir required}"
  shift 3
  local cmd="$*"
  [ -n "$cmd" ] || { echo "perch: command required" >&2; exit 1; }
  case "$name" in
    *'|'*|*' '*) echo "perch: name cannot contain spaces or '|'" >&2; exit 1 ;;
    help|list|stop|add|remove|config) echo "perch: '$name' is a reserved word" >&2; exit 1 ;;
  esac
  if lookup "$name" >/dev/null; then
    echo "perch: '$name' is already registered (perch remove $name first)" >&2
    exit 1
  fi
  mkdir -p "$(dirname "$CONFIG")"
  printf '%s|%s|%s|%s\n' "$name" "$port" "$dir" "$cmd" >>"$CONFIG"
  echo "[perch] registered '$name' (port $port)"
}

cmd_remove() {
  local name="${1:?usage: perch remove <name>}"
  lookup "$name" >/dev/null || { echo "perch: unknown project '$name'" >&2; exit 1; }
  local tmp
  tmp="$(mktemp)"
  awk -F'|' -v n="$name" '$1 != n' "$CONFIG" >"$tmp"
  mv "$tmp" "$CONFIG"
  echo "[perch] removed '$name'"
}

cat_label() {
  case "$1" in
    metro)   printf 'Metro (React Native)' ;;
    landing) printf 'Landing pages & sites' ;;
    web)     printf 'Web apps & dashboards' ;;
    backend) printf 'Backend servers' ;;
    admin)   printf 'Admin panels' ;;
    other)   printf 'Other' ;;
    *)       printf '%s' "$1" ;;
  esac
}

cat_override() {
  [ -f "$CATEGORIES" ] || return 1
  local wanted="$1" n c
  while IFS='|' read -r n c; do
    [ "$n" = "$wanted" ] && { printf '%s' "$c"; return 0; }
  done < <(grep -vE '^\s*(#|$)' "$CATEGORIES")
  return 1
}

categorize() {
  local name="$1" port="$2" lc ovr
  if ovr="$(cat_override "$name")"; then printf '%s' "$ovr"; return; fi
  lc="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')"
  case "$lc" in *metro*) echo metro; return ;; esac
  case "$lc" in *admin*) echo admin; return ;; esac
  case "$lc" in *backend*|*-api) echo backend; return ;; esac
  case "$port" in
    8000|8001|8080) echo backend; return ;;
    8082|8083|8084|8085|8086|8087|8088|8089|8090|8091) echo metro; return ;;
  esac
  case "$lc" in *landing*|*portfolio*|*website*) echo landing; return ;; esac
  [ "$port" = "-" ] && { echo other; return; }
  echo web
}

# Interactive multi-select picker. Pre-checks saved favorites, saves the new
# selection, and launches everything in CAT_ORDER (Metro → Landing → Web → Backend → Admin).
cmd_pick() {
  local -a NAMES PORTS DIRS CMDS CATS SEL ORDER
  local name port dir cmd
  while IFS='|' read -r name port dir cmd; do
    NAMES+=("$name"); PORTS+=("$port"); DIRS+=("$dir"); CMDS+=("$cmd")
    CATS+=("$(categorize "$name" "$port")"); SEL+=(0)
  done < <(config_lines)
  local n=${#NAMES[@]}
  [ "$n" -gt 0 ] || { echo "perch: no projects registered (perch add ...)"; return 1; }

  local i fav
  if [ -f "$FAVORITES" ]; then
    while IFS= read -r fav; do
      [ -n "$fav" ] || continue
      for i in $(seq 0 $((n-1))); do [ "${NAMES[$i]}" = "$fav" ] && SEL[$i]=1; done
    done < "$FAVORITES"
  fi

  local cat
  for cat in $CAT_ORDER; do
    for i in $(seq 0 $((n-1))); do [ "${CATS[$i]}" = "$cat" ] && ORDER+=("$i"); done
  done
  for i in $(seq 0 $((n-1))); do
    case " $CAT_ORDER " in *" ${CATS[$i]} "*) ;; *) ORDER+=("$i") ;; esac
  done
  local m=${#ORDER[@]}

  local line tok a b d ii total on val pos disp lastcat box status
  while true; do
    clear 2>/dev/null || printf '\n'
    printf '  \033[1mperch favorites\033[0m — pick projects, launch order: \033[36mMetro → Landing → Web → Backend → Admin\033[0m\n'
    disp=1; lastcat=""
    for pos in $(seq 0 $((m-1))); do
      i=${ORDER[$pos]}
      if [ "${CATS[$i]}" != "$lastcat" ]; then
        lastcat="${CATS[$i]}"; printf '\n  \033[1;36m%s\033[0m\n' "$(cat_label "$lastcat")"
      fi
      if [ "${SEL[$i]}" = "1" ]; then box="[\033[32mx\033[0m]"; else box="[ ]"; fi
      status=""
      if [ "${PORTS[$i]}" != "-" ] && lsof -ti tcp:"${PORTS[$i]}" >/dev/null 2>&1; then status="\033[33m● up\033[0m"; fi
      printf '   %b %2d. %-27s \033[2m:%-5s\033[0m %b\n' "$box" "$disp" "${NAMES[$i]}" "${PORTS[$i]}" "$status"
      disp=$((disp+1))
    done
    printf '\n  \033[2mtoggle: numbers "1 3 5" · range "1-5" · group "metro landing web backend admin" · all · none · up\033[0m\n'
    printf '  \033[2m[enter] launch selected · q cancel\033[0m\n  > '
    IFS= read -r line || line="q"
    line="$(printf '%s' "$line" | tr '[:upper:]' '[:lower:]')"
    case "$line" in
      ""|start|go|launch|s) break ;;
      q|quit|cancel) echo "  cancelled"; return 1 ;;
      all) for i in $(seq 0 $((n-1))); do SEL[$i]=1; done ;;
      none) for i in $(seq 0 $((n-1))); do SEL[$i]=0; done ;;
      up) for i in $(seq 0 $((n-1))); do if [ "${PORTS[$i]}" != "-" ] && lsof -ti tcp:"${PORTS[$i]}" >/dev/null 2>&1; then SEL[$i]=1; fi; done ;;
      *)
        for tok in $line; do
          case "$tok" in
            metro|landing|web|backend|admin|other)
              total=0; on=0
              for i in $(seq 0 $((n-1))); do
                if [ "${CATS[$i]}" = "$tok" ]; then total=$((total+1)); [ "${SEL[$i]}" = "1" ] && on=$((on+1)); fi
              done
              val=1; { [ "$total" -gt 0 ] && [ "$on" = "$total" ]; } && val=0
              for i in $(seq 0 $((n-1))); do [ "${CATS[$i]}" = "$tok" ] && SEL[$i]=$val; done ;;
            *[0-9]-[0-9]*)
              a="${tok%-*}"; b="${tok#*-}"
              if [ "$a" -ge 1 ] 2>/dev/null && [ "$b" -le "$m" ] 2>/dev/null && [ "$a" -le "$b" ] 2>/dev/null; then
                for d in $(seq "$a" "$b"); do ii=${ORDER[$((d-1))]}; SEL[$ii]=$((1-SEL[ii])); done
              fi ;;
            *[!0-9]*) : ;;
            *)
              if [ "$tok" -ge 1 ] 2>/dev/null && [ "$tok" -le "$m" ] 2>/dev/null; then
                ii=${ORDER[$((tok-1))]}; SEL[$ii]=$((1-SEL[ii]))
              fi ;;
          esac
        done ;;
    esac
  done

  local -a PICK
  for pos in $(seq 0 $((m-1))); do i=${ORDER[$pos]}; [ "${SEL[$i]}" = "1" ] && PICK+=("$i"); done
  [ "${#PICK[@]}" -gt 0 ] || { echo "  nothing selected"; return 1; }

  mkdir -p "$(dirname "$FAVORITES")"; : > "$FAVORITES"
  for i in "${PICK[@]}"; do echo "${NAMES[$i]}" >> "$FAVORITES"; done

  printf '\n[perch] launching %d project(s) in order:\n' "${#PICK[@]}"
  lastcat=""
  local first=1
  for i in "${PICK[@]}"; do
    if [ "${CATS[$i]}" != "$lastcat" ]; then lastcat="${CATS[$i]}"; [ "$first" = "1" ] || sleep 1; fi
    first=0
    launch "${NAMES[$i]}" "${DIRS[$i]}" "${PORTS[$i]}" "${CMDS[$i]}"
    sleep 1
  done
  echo "[perch] saved $((${#PICK[@]})) favorite(s) → re-launch anytime with: perch fav go"
}

# Launch the saved favorites directly, in CAT_ORDER, without the menu.
cmd_fav_go() {
  [ -s "$FAVORITES" ] || { echo "[perch] no favorites yet — run: perch fav"; return 1; }
  local -a FN FP FD FC FK
  local fav entry p d c
  while IFS= read -r fav; do
    [ -n "$fav" ] || continue
    if entry="$(lookup "$fav")"; then
      IFS='|' read -r p d c <<<"$entry"
      FN+=("$fav"); FP+=("$p"); FD+=("$d"); FC+=("$c"); FK+=("$(categorize "$fav" "$p")")
    else
      echo "[perch] skip stale favorite '$fav' (not in registry)"
    fi
  done < "$FAVORITES"
  local cnt=${#FN[@]}
  [ "$cnt" -gt 0 ] || { echo "[perch] favorites empty/stale — run: perch fav"; return 1; }
  echo "[perch] launching favorites ($cnt): ${FN[*]}"
  local cat j first=1
  for cat in $CAT_ORDER; do
    for j in $(seq 0 $((cnt-1))); do
      if [ "${FK[$j]}" = "$cat" ]; then
        [ "$first" = "1" ] || sleep 1; first=0
        launch "${FN[$j]}" "${FD[$j]}" "${FP[$j]}" "${FC[$j]}"
      fi
    done
  done
  # final placement pass — reliable even if per-launch moves lagged under load
  if yabai_available; then
    sleep 2
    echo "[perch] placing windows onto their desktops..."
    cmd_place fav
  fi
}

cmd_fav_list() {
  [ -s "$FAVORITES" ] || { echo "[perch] no favorites set (perch fav)"; return 0; }
  echo "[perch] favorites ($(grep -c . "$FAVORITES")):"; sed 's/^/  /' "$FAVORITES"
}

cmd_fav_clear() {
  mkdir -p "$(dirname "$FAVORITES")"; : > "$FAVORITES"
  echo "[perch] favorites cleared"
}

cmd_fav_set() {
  [ "$#" -ge 1 ] || { echo "usage: perch fav set <name...>" >&2; exit 1; }
  mkdir -p "$(dirname "$FAVORITES")"
  local tmp name ok=0
  tmp="$(mktemp)"
  for name in "$@"; do
    if lookup "$name" >/dev/null; then
      grep -qxF "$name" "$tmp" 2>/dev/null || { echo "$name" >>"$tmp"; ok=$((ok+1)); }
    else
      echo "perch: unknown project '$name' (skipped)" >&2
    fi
  done
  mv "$tmp" "$FAVORITES"
  echo "[perch] set $ok favorite(s)"
  cmd_fav_list
}

cmd_fav_add() {
  [ "$#" -ge 1 ] || { echo "usage: perch fav add <name...>" >&2; exit 1; }
  mkdir -p "$(dirname "$FAVORITES")"; touch "$FAVORITES"
  local name
  for name in "$@"; do
    if lookup "$name" >/dev/null; then
      grep -qxF "$name" "$FAVORITES" || echo "$name" >>"$FAVORITES"
    else
      echo "perch: unknown project '$name' (skipped)" >&2
    fi
  done
  cmd_fav_list
}

cmd_fav() {
  local sub="${1:-}"
  [ "$#" -ge 1 ] && shift
  case "$sub" in
    go|run|launch) cmd_fav_go ;;
    set) cmd_fav_set "$@" ;;
    add) cmd_fav_add "$@" ;;
    list|ls) cmd_fav_list ;;
    clear|reset) cmd_fav_clear ;;
    ""|pick|edit|choose) cmd_pick ;;
    *) echo "perch: unknown fav subcommand '$sub' (go|set|add|list|clear|pick)" >&2; exit 1 ;;
  esac
}

cmd_killall() {
  local close=0 onlyfav=0 arg
  for arg in "$@"; do
    case "$arg" in
      --close|close|tabs) close=1 ;;
      fav|favorites|favourites|--fav) onlyfav=1 ;;
    esac
  done

  local -a NAMES PORTS
  local name port dir cmd fav entry p d c
  if [ "$onlyfav" = "1" ]; then
    [ -s "$FAVORITES" ] || { echo "[perch] no favorites set"; return 0; }
    while IFS= read -r fav; do
      [ -n "$fav" ] || continue
      if entry="$(lookup "$fav")"; then IFS='|' read -r p d c <<<"$entry"; NAMES+=("$fav"); PORTS+=("$p"); fi
    done < "$FAVORITES"
  else
    while IFS='|' read -r name port dir cmd; do NAMES+=("$name"); PORTS+=("$port"); done < <(config_lines)
  fi

  local n=${#NAMES[@]}
  [ "$n" -gt 0 ] || { echo "[perch] nothing registered to stop"; return 0; }

  local i pids killed=0
  for i in $(seq 0 $((n-1))); do
    [ "${PORTS[$i]}" = "-" ] && continue
    pids="$(lsof -ti tcp:"${PORTS[$i]}" 2>/dev/null || true)"
    if [ -n "$pids" ]; then
      # shellcheck disable=SC2086
      kill -9 $pids 2>/dev/null || true
      echo "[perch] stopped ${NAMES[$i]} (port ${PORTS[$i]})"
      killed=$((killed+1))
    fi
  done
  echo "[perch] killall: stopped $killed running server(s)$( [ "$onlyfav" = "1" ] && echo ' from favorites' )"

  if [ "$close" = "1" ]; then
    local listexpr="" mk
    for i in $(seq 0 $((n-1))); do
      mk="$(printf '%s' "${NAMES[$i]}" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
      if [ -z "$listexpr" ]; then listexpr="\"$mk\""; else listexpr="$listexpr, \"$mk\""; fi
    done

    # 1) collect the tty of every tab in matching windows
    local ttyfile; ttyfile="$(mktemp)"
    /usr/bin/osascript >"$ttyfile" 2>/dev/null <<OSA
tell application "Terminal"
  set markerList to {$listexpr}
  set outT to ""
  repeat with w in windows
    try
      set matched to false
      repeat with t in tabs of w
        try
          if markerList contains (custom title of t) then set matched to true
        end try
      end repeat
      if matched then
        repeat with t in tabs of w
          try
            set outT to outT & (tty of t) & linefeed
          end try
        end repeat
      end if
    end try
  end repeat
  return outT
end tell
OSA

    # 2) kill every process on those ttys so the window goes idle
    #    (Terminal's "terminate running processes?" prompt only appears when a
    #    window still has a live process; killing the tty group avoids it)
    local tt selftty pids2
    selftty="$(tty 2>/dev/null || true)"
    while IFS= read -r tt; do
      [ -n "$tt" ] || continue
      [ "$tt" = "$selftty" ] && continue
      pids2="$(ps -t "${tt#/dev/}" -o pid= 2>/dev/null | tr '\n' ' ' || true)"
      # shellcheck disable=SC2086
      [ -n "$pids2" ] && kill -9 $pids2 2>/dev/null || true
    done < "$ttyfile"
    rm -f "$ttyfile"
    sleep 1

    # 3) close the now-idle windows (no prompt)
    /usr/bin/osascript >/dev/null 2>&1 <<OSA
tell application "Terminal"
  set markerList to {$listexpr}
  set toClose to {}
  repeat with w in windows
    try
      repeat with t in tabs of w
        try
          if markerList contains (custom title of t) then
            set end of toClose to w
            exit repeat
          end if
        end try
      end repeat
    end try
  end repeat
  repeat with w in toClose
    try
      close w saving no
    end try
  end repeat
end tell
OSA
    echo "[perch] closed matching Terminal tabs"
  fi
}

# (Re)assign already-open server windows to their mapped desktops (yabai) without
# restarting them. Robust against launch-time races (heavy load delays yabai's
# window indexing, so per-launch moves can miss; this pass runs once, later).
cmd_place() {
  if ! yabai_available; then echo "[perch] yabai not running (or PERCH_USE_YABAI=0) — nothing to place"; return 0; fi
  ensure_spaces_seeded
  local onlyfav=0 tile arg
  [ "$(pget tile on)" = "off" ] && tile=0 || tile=1
  for arg in "$@"; do
    case "$arg" in
      fav|favorites|favourites|--fav) onlyfav=1 ;;
      notile|--no-tile|free) tile=0 ;;
      tile|--tile) tile=1 ;;
    esac
  done
  local -a NAMES PORTS
  local name port dir cmd fav entry p d c
  if [ "$onlyfav" = "1" ]; then
    [ -s "$FAVORITES" ] || { echo "[perch] no favorites set"; return 0; }
    while IFS= read -r fav; do
      [ -n "$fav" ] || continue
      if entry="$(lookup "$fav")"; then IFS='|' read -r p d c <<<"$entry"; NAMES+=("$fav"); PORTS+=("$p"); fi
    done < "$FAVORITES"
  else
    while IFS='|' read -r name port dir cmd; do NAMES+=("$name"); PORTS+=("$port"); done < <(config_lines)
  fi
  local n=${#NAMES[@]}
  [ "$n" -gt 0 ] || { echo "[perch] nothing to place"; return 0; }

  # pass 1: move each open window to its mapped desktop
  local -a PN PW PS
  local i cat sp wid
  for i in $(seq 0 $((n-1))); do
    cat="$(categorize "${NAMES[$i]}" "${PORTS[$i]}")"
    sp="$(resolve_space "$(space_for "${NAMES[$i]}" "$cat")")"
    [ -n "$sp" ] || continue
    wid="$(yabai_window_id "${NAMES[$i]}")"
    [ -n "$wid" ] || continue
    yabai -m window "$wid" --space "$sp" 2>/dev/null || true
    PN+=("${NAMES[$i]}"); PW+=("$wid"); PS+=("$sp")
  done
  local placed=${#PN[@]}
  [ "$placed" -gt 0 ] || { echo "[perch] no open windows to place"; return 0; }

  if [ "$tile" = "1" ]; then
    # pass 2: per desktop, tile windows full-width and stacked one after another
    # (yabai grid N:1:0:row:1:1 = N rows × 1 col, full width, this window at 'row')
    local -a SEEN
    local a b spx count row fr
    for a in $(seq 0 $((placed-1))); do
      spx="${PS[$a]}"
      case " ${SEEN[*]:-} " in *" $spx "*) continue ;; esac
      SEEN+=("$spx")
      count=0
      for b in $(seq 0 $((placed-1))); do [ "${PS[$b]}" = "$spx" ] && count=$((count+1)); done
      row=0
      for b in $(seq 0 $((placed-1))); do
        if [ "${PS[$b]}" = "$spx" ]; then
          yabai -m window "${PW[$b]}" --grid "$count:1:0:$row:1:1" 2>/dev/null || true
          [ "$REMEMBER_BOUNDS" = "1" ] && { fr="$(yabai_frame "${PW[$b]}")"; [ -n "$fr" ] && bounds_save "${PN[$b]}" "$fr"; }
          echo "[perch] ${PN[$b]} → desktop $spx  (row $((row+1))/$count, full width)"
          row=$((row+1))
        fi
      done
    done
  else
    local k fr
    for k in $(seq 0 $((placed-1))); do
      [ "$REMEMBER_BOUNDS" = "1" ] && { fr="$(yabai_frame "${PW[$k]}")"; [ -n "$fr" ] && bounds_save "${PN[$k]}" "$fr"; }
      echo "[perch] placed ${PN[$k]} → desktop ${PS[$k]}"
    done
  fi
  echo "[perch] place: arranged $placed window(s)$( [ "$tile" = "1" ] && echo ' (full-width, stacked)' )"
}

cmd_set() {
  if [ "$#" -eq 0 ]; then
    echo "[perch] settings ($SETTINGS):"
    echo "  placement = $(pget placement on)    # assign windows to desktops (needs yabai)"
    echo "  tile      = $(pget tile on)    # full-width, stacked tiling on each desktop"
    echo "toggle with: perch set placement off   |   perch set tile off"
    return 0
  fi
  local key="$1" val="${2:-}"
  case "$key" in
    placement|tile)
      case "$val" in
        on|off) pset "$key" "$val"; echo "[perch] $key = $val" ;;
        *) echo "usage: perch set $key <on|off>" >&2; exit 1 ;;
      esac ;;
    *) echo "perch: unknown setting '$key' (placement|tile)" >&2; exit 1 ;;
  esac
}

perch_realpath() {
  local src="${BASH_SOURCE[0]:-$0}" dir
  while [ -h "$src" ]; do
    dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
    src="$(readlink "$src")"
    case "$src" in /*) ;; *) src="$dir/$src" ;; esac
  done
  printf '%s' "$src"
}

cmd_gui() {
  local sub="${1:-open}" port="${PERCH_GUI_PORT:-7620}"
  local real dir py pids
  real="$(perch_realpath)"; dir="$(cd -P "$(dirname "$real")" >/dev/null 2>&1 && pwd)"; py="$dir/perch-gui.py"
  case "$sub" in
    stop|off)
      pids="$(lsof -ti tcp:"$port" 2>/dev/null || true)"
      if [ -n "$pids" ]; then kill $pids 2>/dev/null || true; echo "[perch] gui stopped (port $port)"; else echo "[perch] gui not running"; fi
      ;;
    *)
      [ -f "$py" ] || { echo "perch: gui script not found at $py" >&2; exit 1; }
      command -v python3 >/dev/null 2>&1 || { echo "perch: python3 required for the gui" >&2; exit 1; }
      if ! lsof -ti tcp:"$port" >/dev/null 2>&1; then
        PERCH_BIN="$real" PERCH_GUI_PORT="$port" PERCH_CONFIG="$CONFIG" PERCH_FAVORITES="$FAVORITES" \
        PERCH_SETTINGS="$SETTINGS" PERCH_SPACES="$SPACES" \
          nohup python3 "$py" >/dev/null 2>&1 &
        sleep 1
        echo "[perch] gui started → http://localhost:$port"
      else
        echo "[perch] gui already running → http://localhost:$port"
      fi
      open "http://localhost:$port" >/dev/null 2>&1 || true
      ;;
  esac
}

# Auto-detect displays/desktops and write a spaces.conf tuned to THIS machine.
seed_spaces() {
  command -v yabai >/dev/null 2>&1 && yabai -m query --spaces >/dev/null 2>&1 || return 1
  command -v python3 >/dev/null 2>&1 || return 1
  PERCH_SPACES="$SPACES" python3 - <<'PY'
import json, subprocess, os
from collections import defaultdict
SPACES = os.environ["PERCH_SPACES"]
disp = json.loads(subprocess.check_output(["yabai","-m","query","--displays"]))
spc  = json.loads(subprocess.check_output(["yabai","-m","query","--spaces"]))
byd = defaultdict(list)
for s in sorted(spc, key=lambda s: s["index"]):
    if not s.get("is-native-fullscreen"):
        byd[s["display"]].append(s["index"])
def area(d): f = d["frame"]; return f["w"] * f["h"]
def origin(d): f = d["frame"]; return f["x"] == 0 and f["y"] == 0
cands = [d for d in disp if byd.get(d["index"])] or disp
# prefer: most real desktops, then external (not at origin), then larger
target = max(cands, key=lambda d: (len(byd.get(d["index"], [])), 0 if origin(d) else 1, area(d)))
tdi = target["index"]; N = len(byd.get(tdi, [])) or 1
f = target["frame"]; ori = "portrait" if f["h"] > f["w"] else "landscape"
if   N >= 4: server = [2, 3, 4]   # reserve desktop 1 for working
elif N == 3: server = [1, 2, 3]
elif N == 2: server = [1, 2]
else:        server = [1]
k = len(server); groups = [("metro",), ("landing", "web"), ("backend", "admin")]
lines = ["# perch desktop map - auto-generated by `perch setup` for this machine.",
         "# name|<display>:<desktop-ordinal>  (real desktops only, not fullscreen spaces).",
         "# Re-run `perch setup` if you change monitors, or drag + Save in `perch gui`.",
         "# Target: display %d (%s %dx%d), %d desktop(s); servers on desktop(s) %s."
         % (tdi, ori, int(f["w"]), int(f["h"]), N, ",".join(map(str, server)))]
for gi, g in enumerate(groups):
    o = server[min(gi * k // 3, k - 1)]
    for cat in g:
        lines.append("%s|%d:%d" % (cat, tdi, o))
os.makedirs(os.path.dirname(SPACES), exist_ok=True)
open(SPACES, "w").write("\n".join(lines) + "\n")
print("display %d (%s), %d desktop(s), servers on desktop(s) %s" % (tdi, ori, N, server))
PY
}

# Seed the map on first use if it does not exist yet (so a fresh machine works).
ensure_spaces_seeded() {
  [ -f "$SPACES" ] && return 0
  yabai -m query --spaces >/dev/null 2>&1 || return 0
  seed_spaces >/dev/null 2>&1 || true
}

cmd_setup() {
  if ! command -v yabai >/dev/null 2>&1; then
    echo "[perch] yabai isn't installed — desktop placement is optional and will be skipped."
    echo "        to enable it: brew install koekeishiya/formulae/yabai && yabai --start-service"
    echo "        then grant Accessibility to yabai in System Settings › Privacy & Security."
    return 0
  fi
  if ! yabai -m query --spaces >/dev/null 2>&1; then
    echo "[perch] yabai is installed but not responding."
    echo "        run: yabai --start-service   and grant it Accessibility, then re-run: perch setup"
    return 0
  fi
  echo "[perch] detecting your displays…"
  if seed_spaces; then
    echo "[perch] wrote $SPACES:"
    grep -vE '^[[:space:]]*#' "$SPACES" | sed 's/^/    /'
    echo "        tweak it by editing that file or dragging in \`perch gui\`, then \`perch place\`."
  else
    echo "[perch] auto-detect needs python3 + a running yabai."
  fi
}

cmd_doctor() {
  local G="" A="" D="" R=""
  if [ -t 1 ]; then G=$'\033[32m'; A=$'\033[33m'; D=$'\033[2m'; R=$'\033[0m'; fi
  local ok="${G}✓${R}" warn="${A}!${R}" need=0
  # row STATUS LABEL DETAIL ; fix lines follow via `fix`
  row() { printf '  %s  %-13s %s\n' "$1" "$2" "$3"; }
  fix() { printf '       %s%s%s\n' "$D" "$1" "$R"; need=1; }

  echo "perch $PERCH_VERSION · doctor"; echo

  if command -v osascript >/dev/null 2>&1; then row "$ok" "osascript" "Terminal control (macOS built-in)"
  else row "$warn" "osascript" "missing — not a standard macOS environment"; need=1; fi

  if command -v python3 >/dev/null 2>&1; then row "$ok" "python3" "web gui + auto-setup"
  else row "$warn" "python3" "missing — needed for the gui and 'perch setup'"; fix "xcode-select --install"; fi

  if command -v yabai >/dev/null 2>&1; then
    if yabai -m query --spaces >/dev/null 2>&1; then
      row "$ok" "yabai" "desktop placement · $(yabai -m query --displays 2>/dev/null | grep -c '"id"') display(s)"
    else
      row "$warn" "yabai" "installed but not responding"
      fix "yabai --start-service"
      fix 'open "x-apple.systempreferences:com.apple.preference.security?Privacy_Accessibility"'
    fi
  else
    row "$warn" "yabai" "absent — placement optional (auto-skips without it)"
    fix "brew install koekeishiya/formulae/yabai"
    fix "yabai --start-service"
    fix 'open "x-apple.systempreferences:com.apple.preference.security?Privacy_Accessibility"'
  fi

  row "$ok" "settings" "placement=$(pget placement on), tile=$(pget tile on)"

  local pc fc
  pc="$(config_lines 2>/dev/null | grep -c . || true)"; pc="${pc:-0}"
  if [ "$pc" -gt 0 ] 2>/dev/null; then row "$ok" "projects" "$pc registered"
  else row "$warn" "projects" "none registered yet"; fix 'perch add <name> <port> <dir> "<command>"'; fi

  fc=0; [ -f "$FAVORITES" ] && fc="$(grep -c . "$FAVORITES" 2>/dev/null || true)"; fc="${fc:-0}"
  if [ "$fc" -gt 0 ] 2>/dev/null; then row "$ok" "favorites" "$fc set"
  else row "$warn" "favorites" "none set — pick your working set"; fix "perch fav"; fi

  if [ -f "$SPACES" ]; then row "$ok" "desktop map" "$SPACES"
  else row "$warn" "desktop map" "not created (auto-seeds on first place, or run:)"; fix "perch setup"; fi

  echo
  if [ "$need" = "0" ]; then printf '  %sall good.%s\n' "$G" "$R"
  else printf '  %scopy-paste the indented commands above to fix.%s\n' "$D" "$R"; fi
}

cmd_bounds() {
  case "${1:-list}" in
    list|ls)
      [ -s "$BOUNDS" ] || { echo "[perch] no remembered window positions yet"; return 0; }
      printf '%-28s %s\n' 'PROJECT' 'x1 y1 x2 y2 (left top right bottom)'
      local n a b c d
      while IFS='|' read -r n a b c d; do printf '%-28s %s %s %s %s\n' "$n" "$a" "$b" "$c" "$d"; done < "$BOUNDS" ;;
    clear|reset|forget)
      if [ -n "${2:-}" ]; then
        [ -f "$BOUNDS" ] || return 0
        local tmp; tmp="$(mktemp)"; awk -F'|' -v n="$2" '$1 != n' "$BOUNDS" >"$tmp"; mv "$tmp" "$BOUNDS"
        echo "[perch] forgot window position for '$2'"
      else
        mkdir -p "$(dirname "$BOUNDS")"; : > "$BOUNDS"; echo "[perch] forgot all window positions"
      fi ;;
    *) echo "usage: perch bounds [list|clear [name]]" >&2; exit 1 ;;
  esac
}

cmd_port() {
  # Print the perch-assigned port for a project. With a name, look it up; with no
  # arg, resolve by the current working directory. Used inside projects' own start
  # scripts: `next dev -p $(perch port 2>/dev/null || echo 3000)`.
  local name="${1:-}"
  if [ -n "$name" ]; then
    local e; e="$(lookup "$name")" || return 1
    printf '%s\n' "${e%%|*}"; return 0
  fi
  local cwd; cwd="$(pwd -P 2>/dev/null || pwd)"
  local n p d c dd
  while IFS='|' read -r n p d c; do
    case "$n" in ''|\#*) continue ;; esac
    dd="$(expand_path "$d")"; dd="$(cd "$dd" 2>/dev/null && pwd -P)" || continue
    if [ "$dd" = "$cwd" ]; then printf '%s\n' "$p"; return 0; fi
  done < <(config_lines)
  return 1
}

cat_rank() { case "$1" in backend) echo 0;; landing) echo 1;; web) echo 2;; admin) echo 3;; metro) echo 4;; *) echo 5;; esac; }

# Auto-group projects by product = the name up to the first "-" (jakstoc-web -> jakstoc).
cmd_groups() {
  config_lines | grep -q . || { echo "perch: no projects registered yet ($CONFIG)"; return 0; }
  local tmp; tmp="$(mktemp)"
  local name port dir cmd g status
  while IFS='|' read -r name port dir cmd; do
    case "$name" in ''|\#*) continue ;; esac
    g="${name%%-*}"; status='.'
    if [ "$port" != "-" ] && lsof -ti tcp:"$port" >/dev/null 2>&1; then status='up'; fi
    printf '%s\t%s\t%s\t%s\n' "$g" "$name" "$port" "$status" >> "$tmp"
  done < <(config_lines)
  sort -o "$tmp" "$tmp"
  awk -F'\t' '
    NR==FNR { cnt[$1]++; next }
    { if ($1!=cur){ cur=$1; lbl=toupper(substr($1,1,1)) substr($1,2);
        printf "\n%s%s\n", lbl, (cnt[$1]>=2 ? "  ("cnt[$1]" projects  ·  start all: perch "$1")" : "") }
      printf "   %-3s %-27s %s\n", ($4=="up"?"up":""), $2, ($3=="-"?"-":":" $3) }
  ' "$tmp" "$tmp"
  rm -f "$tmp"
}

# Launch every project whose name starts with <prefix> (backend first). `perch jakstoc`
# or `perch 'jakstoc*'` -> starts jakstoc-api, jakstoc-landing-page, jakstoc-web, jakstoc-admin.
cmd_start_group() {
  local pref="${1%\*}"
  [ -n "$pref" ] || return 1
  local -a ranked=()
  local name port dir cmd
  while IFS='|' read -r name port dir cmd; do
    case "$name" in ''|\#*) continue ;; esac
    case "$name" in "$pref"*) ranked+=("$(cat_rank "$(categorize "$name" "$port")")|$name") ;; esac
  done < <(config_lines)
  [ "${#ranked[@]}" -gt 0 ] || return 1
  echo "[perch] starting ${#ranked[@]} project(s) matching '${pref}*' (backend first)…"
  local line n e p d c
  while IFS= read -r line; do
    n="${line#*|}"; e="$(lookup "$n")" || continue
    IFS='|' read -r p d c <<<"$e"
    ( launch "$n" "$d" "$p" "$c" ) || echo "[perch] skipped $n (error)"
  done < <(printf '%s\n' "${ranked[@]}" | sort -n -t'|' -k1,1)
  return 0
}

help_for() {
  local topic="$*"
  case "$topic" in
    ""|help) usage ;;
    fav|favorites|favourites) cat <<'EOF'
perch fav — manage and launch your favorite projects (a saved shortlist of registered projects).

USAGE
  perch fav                 open the interactive multi-select picker, then save + launch the chosen set
  perch fav go              launch the saved favorites, no menu
  perch fav set <name...>   replace the favorites list with exactly these projects
  perch fav add <name...>   add projects to favorites (keeps the existing ones)
  perch fav list            print the saved favorites
  perch fav clear           empty the favorites list
  perch fav pick            alias for `perch fav` (the picker)

Favorites are the set that `perch fav go` and `perch place fav` act on.
Run `perch fav <subcommand> help` for detail on any of these.
EOF
    ;;
    "fav go"|"fav run"|"fav launch") cat <<'EOF'
perch fav go — launch every project in your favorites, each in its own reused Terminal tab.

USAGE
  perch fav go

No menu, no prompts. Ports are freed first, tabs are reused by marker, and windows
auto-place if placement is on. Use `perch fav` when you want to choose interactively.
EOF
    ;;
    "fav set") cat <<'EOF'
perch fav set — replace the ENTIRE favorites list with the names you pass.

USAGE
  perch fav set <name> [name...]

Example
  perch fav set rentwize-metro podzyme-metro rentwize-backend

Overwrites the previous list. Use `perch fav add` to append instead.
