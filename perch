}

main() {
  local first="${1:-help}"
  # nested help at any level: `perch help [path...]`  or  `perch [path...] help|-h|--help`
  case "$first" in help|-h|--help) shift; help_for "$@"; return ;; esac
  if [ "$#" -ge 2 ]; then
    case "${@: -1}" in
      help|-h|--help) set -- "${@:1:$(($#-1))}"; help_for "$@"; return ;;
    esac
  fi
  case "$first" in
    help|-h|--help) usage ;;
    -v|--version) echo "perch $PERCH_VERSION" ;;
    fav|favorites|favourites) shift; cmd_fav "$@" ;;
    pick|choose) cmd_pick ;;
    bounds|pos|position) shift; cmd_bounds "$@" ;;
    killall|kill-all|stopall) shift; cmd_killall "$@" ;;
    place|arrange) shift; cmd_place "$@" ;;
    set|settings) shift; cmd_set "$@" ;;
    gui|dashboard|ui) shift; cmd_gui "$@" ;;
    setup) cmd_setup ;;
    doctor|check) cmd_doctor ;;
    list|ls) cmd_list ;;
    groups|clusters|cluster|by-product) cmd_groups ;;
    stop)
      shift
      if [ "${1:-}" = "all" ]; then shift; cmd_killall "$@"; else cmd_stop "$@"; fi ;;
    add) shift; cmd_add "$@" ;;
    remove|rm) shift; cmd_remove "$@" ;;
    config) echo "$CONFIG" ;;
    port) shift; cmd_port "$@" || { echo "perch: no port for $([ -n "${1:-}" ] && echo "'$1'" || echo 'this directory')" >&2; exit 1; } ;;
    *)
      if [ $# -eq 1 ]; then
        local entry
        if entry="$(lookup "$first")"; then
          local port dir cmd
          IFS='|' read -r port dir cmd <<<"$entry"
          launch "$first" "$dir" "$port" "$cmd"
        elif cmd_start_group "$first"; then
          :
        else
          echo "perch: unknown project or prefix '$first' (see: perch list / perch groups)" >&2
          exit 1
        fi
      elif [ $# -ge 4 ]; then
        local marker="$1" dir="$2" port="$3"
        shift 3
        launch "$marker" "$dir" "$port" "$*"
      else
        usage >&2
        exit 1
      fi
      ;;
  esac
}

main "$@"
